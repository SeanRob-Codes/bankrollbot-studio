<script>
/* ──────────────────────────────────────────
   STATE
────────────────────────────────────────── */
const STORAGE_KEY = 'bbs_v2';

const DEFAULT = {
  bankroll: 2500,
  unitSize: 25,
  riskMode: 'standard',
  username: '',
  bets: [],
  guardrails: { stopLossOn:false, stopLoss:-5, maxBetsOn:false, maxBets:5, tiltOn:true, kellyOn:true },
  supabase: { url:'', key:'' }
};

let S = loadState();

function loadState(){
  try{
    const r = localStorage.getItem(STORAGE_KEY);
    if(!r) return deepClone(DEFAULT);
    const p = JSON.parse(r);
    return { ...DEFAULT, ...p, guardrails:{...DEFAULT.guardrails,...(p.guardrails||{})}, supabase:{...DEFAULT.supabase,...(p.supabase||{})} };
  }catch{ return deepClone(DEFAULT); }
}

function deepClone(o){ return JSON.parse(JSON.stringify(o)); }

function saveState(){
  localStorage.setItem(STORAGE_KEY, JSON.stringify(S));
  refreshHeader();
  refreshHomeStats();
  refreshProfileUI();
}

/* ──────────────────────────────────────────
   UTILS
────────────────────────────────────────── */
function american2dec(o){ return o>0 ? 1+o/100 : 1+100/Math.abs(o); }
function american2imp(o){ return o>0 ? 100/(o+100) : Math.abs(o)/(Math.abs(o)+100); }
function fmt$(n){ const s=n<0?'-':''; return s+'$'+Math.abs(n).toFixed(0); }
function fmtU(n){ return (n>=0?'+':'')+n.toFixed(1)+'u'; }

function calcStats(){
  const b = S.bets.slice(-30);
  let wins=0,losses=0,net=0;
  const curve=[];
  let running=0;
  for(const x of b){
    if(x.result==='win'){ wins++; running+=(american2dec(x.odds)-1)*x.units; }
    else if(x.result==='loss'){ losses++; running-=x.units; }
    curve.push(+running.toFixed(2));
  }
  const resolved=wins+losses;
  return { wins, losses, net:running, hitRate: resolved? (wins/resolved)*100:null, curve };
}

function tiltStreak(){
  let s=0;
  for(let i=S.bets.length-1;i>=0;i--){
    if(S.bets[i].result==='loss') s++;
    else if(S.bets[i].result==='win') break;
  }
  return s;
}

function initials(name){
  if(!name) return 'BB';
  const p=name.trim().split(/\s+/);
  return p.length===1? p[0].slice(0,2).toUpperCase() : (p[0][0]+p[1][0]).toUpperCase();
}

/* ──────────────────────────────────────────
   NAV
────────────────────────────────────────── */
document.querySelectorAll('.nav-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const id=btn.dataset.screen;
    document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.screen').forEach(s=>{
      s.classList.toggle('active', s.id==='screen-'+id);
    });
  });
});

/* ──────────────────────────────────────────
   HEADER / STATS STRIP
────────────────────────────────────────── */
function refreshHeader(){
  document.getElementById('s-bankroll').textContent='$'+S.bankroll.toFixed(0);
  document.getElementById('s-unit').textContent='1u=$'+S.unitSize.toFixed(0);
  const st=calcStats();
  const hr=document.getElementById('s-hitrate');
  hr.textContent=st.hitRate!==null? st.hitRate.toFixed(1)+'%':'–';
  hr.className='stat-val'+(st.hitRate!==null&&st.hitRate>=52?' up':st.hitRate!==null&&st.hitRate<45?' down':'');
  document.getElementById('s-record').textContent=st.wins+'W/'+st.losses+'L';
  const uEl=document.getElementById('s-units');
  uEl.textContent=fmtU(st.net);
  uEl.className='stat-val'+(st.net>0?' up':st.net<0?' down':'');
  document.getElementById('s-drift').textContent=fmt$(st.net*S.unitSize)+' drift';
}

/* ──────────────────────────────────────────
   CHART
────────────────────────────────────────── */
let perfChart=null;

function refreshChart(){
  const st=calcStats();
  const ctx=document.getElementById('perfChart').getContext('2d');
  const labels=st.curve.map((_,i)=>'#'+(i+1));

  if(perfChart) perfChart.destroy();

  const gradient=ctx.createLinearGradient(0,0,0,180);
  gradient.addColorStop(0,'rgba(0,229,160,0.18)');
  gradient.addColorStop(1,'rgba(0,229,160,0.0)');

  perfChart=new Chart(ctx,{
    type:'line',
    data:{
      labels: labels.length? labels:['Start'],
      datasets:[{
        data: st.curve.length? st.curve:[0],
        borderColor:'#00e5a0',
        borderWidth:2,
        backgroundColor:gradient,
        fill:true,
        tension:0.4,
        pointRadius: st.curve.length>20?0:3,
        pointBackgroundColor:'#00e5a0',
        pointBorderColor:'transparent'
      }]
    },
    options:{
      responsive:true,
      maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{
        backgroundColor:'#141e2e',
        borderColor:'rgba(0,229,160,0.3)',
        borderWidth:1,
        titleColor:'#8a96a8',
        bodyColor:'#00e5a0',
        callbacks:{label:ctx=>fmtU(ctx.parsed.y)}
      }},
      scales:{
        x:{display:false},
        y:{
          display:true,
          grid:{color:'rgba(255,255,255,0.04)'},
          ticks:{color:'#5a6478',font:{family:'DM Mono',size:10},
            callback:v=>fmtU(v)
          }
        }
      }
    }
  });

  document.getElementById('chart-note').textContent =
    st.curve.length? `${st.curve.length} bets tracked (last 30)` : 'Log bets to see your curve';
}

/* ──────────────────────────────────────────
   HOME STATS
────────────────────────────────────────── */
function refreshHomeStats(){ refreshChart(); refreshHeader(); }

/* ──────────────────────────────────────────
   BET LIST
────────────────────────────────────────── */
function renderBetList(){
  const el=document.getElementById('bet-list');
  const empty=document.getElementById('bet-empty');
  el.innerHTML='';

  const bets=[...S.bets].reverse();
  empty.style.display=bets.length?'none':'block';

  bets.forEach(b=>{
    const row=document.createElement('div');
    row.className='bet-item';

    const dot=document.createElement('div');
    dot.className='bet-league-dot';

    const info=document.createElement('div');
    info.className='bet-info';
    info.innerHTML=`
      <div class="bet-name">${b.league} – ${b.market||'Bet'}</div>
      <div class="bet-meta">
        <span>${b.match||'–'}</span>
        <span>Odds: ${b.odds}</span>
        <span>${b.units.toFixed(1)}u</span>
      </div>
    `;

    const actions=document.createElement('div');
    actions.className='bet-actions';

    const pill=document.createElement('div');
    pill.className='result-pill'+(b.result==='win'?' win':b.result==='loss'?' loss':'');
    pill.textContent=b.result==='win'?'W':b.result==='loss'?'L':'–';

    const wBtn=document.createElement('button');
    wBtn.className='mark-btn w';wBtn.textContent='W';
    wBtn.addEventListener('click',()=>{ b.result='win'; saveState(); renderBetList(); });

    const lBtn=document.createElement('button');
    lBtn.className='mark-btn l';lBtn.textContent='L';
    lBtn.addEventListener('click',()=>{ b.result='loss'; saveState(); renderBetList(); });

    actions.append(pill,wBtn,lBtn);
    row.append(dot,info,actions);
    el.appendChild(row);
  });
}

/* Quick add */
document.getElementById('quick-add-btn').addEventListener('click',()=>{
  const league=document.getElementById('q-league').value;
  const match=(document.getElementById('q-match').value||'').trim();
  const market=(document.getElementById('q-market').value||'').trim();
  const odds=parseFloat(document.getElementById('q-odds').value)||(-110);
  const units=parseFloat(document.getElementById('q-units').value)||1;
  if(!market){ alert('Enter a market/prop.'); return; }
  S.bets.push({id:'b'+Date.now().toString(36),league,match,market,odds,units,result:'pending',createdAt:Date.now()});
  saveState(); renderBetList();
  document.getElementById('q-market').value='';
  document.getElementById('q-match').value='';
  guardrailCheck();
});

function guardrailCheck(){
  const st=calcStats();
  if(S.guardrails.stopLossOn && st.net<=S.guardrails.stopLoss){
    alert(`⚠️ Stop-loss reminder: you're at ${fmtU(st.net)} in this demo session.\n\nYou planned to step away here.`);
  }
  if(S.guardrails.maxBetsOn && S.bets.length>=S.guardrails.maxBets){
    alert(`⚠️ Max bets: you planned for ${S.guardrails.maxBets} demo decisions. You've reached it.`);
  }
  if(S.guardrails.tiltOn && tiltStreak()>=2){
    alert(`⚠️ Tilt warning: ${tiltStreak()} consecutive losses. Consider slowing down.`);
  }
}

/* ──────────────────────────────────────────
   AI ANALYZER
────────────────────────────────────────── */
const ANTHROPIC_ENDPOINT = 'https://api.anthropic.com/v1/messages';

document.getElementById('analyze-btn').addEventListener('click', runAnalysis);

async function runAnalysis(){
  const betText=(document.getElementById('a-text').value||'').trim();
  const odds=parseFloat(document.getElementById('a-odds').value);
  const prob=parseFloat(document.getElementById('a-prob').value);
  const units=parseFloat(document.getElementById('a-units').value)||1;
  const conf=document.getElementById('a-conf').value;

  if(!betText){ alert('Describe the bet first.'); return; }
  if(isNaN(odds)){ alert('Enter valid odds.'); return; }
  if(isNaN(prob)||prob<1||prob>99){ alert('Enter your estimated chance (1–99%).'); return; }

  const resultEl=document.getElementById('ai-result');
  resultEl.className='ai-result visible';
  resultEl.innerHTML=`<div class="ai-thinking"><span>Analyzing</span><div class="dots"><span>.</span><span>.</span><span>.</span></div></div>`;

  /* local math */
  const imp=american2imp(odds);
  const yourP=prob/100;
  const dec=american2dec(odds);
  const ev=(yourP*(dec-1)-(1-yourP)*1)*100;
  const edge=(yourP-imp)*100;
  const kelly=Math.max(0,((dec-1)*yourP-(1-yourP))/(dec-1));
  const kellySuggest=(kelly*100).toFixed(1);

  /* build AI prompt */
  const prompt=`You are a sharp sports betting analyst and educator. A user has submitted a demo bet for analysis.

BET DETAILS: ${betText}
ODDS: ${odds} (American)
THEIR ESTIMATED WIN PROBABILITY: ${prob}%
IMPLIED PROBABILITY FROM ODDS: ${(imp*100).toFixed(1)}%
CALCULATED EV: ${ev>=0?'+':''}${ev.toFixed(1)}% per unit staked
EDGE VS MARKET: ${edge>=0?'+':''}${edge.toFixed(1)} percentage points
KELLY CRITERION STAKE: ${kellySuggest}% of bankroll (~${(kelly*units).toFixed(2)}u if staking ${units}u)
STATED CONFIDENCE: ${conf}

Write a concise 3-4 sentence analysis covering:
1. Whether this looks like a +EV play based on their probability estimate vs the market
2. One relevant sharp-money consideration or line shopping note
3. A brief risk/sizing comment referencing Kelly
4. A one-sentence verdict: PLAY / PASS / WATCH

Be direct, specific, and use the actual numbers. Keep it under 120 words. Do not use bullet points.`;

  try{
    const resp=await fetch(ANTHROPIC_ENDPOINT,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        messages:[{role:'user',content:prompt}]
      })
    });
    const data=await resp.json();
    const aiText=data.content?.[0]?.text||'Analysis unavailable.';

    const isPos=ev>1;
    resultEl.innerHTML=`
      <div class="ai-verdict ${isPos?'pos':'neg'}">
        <div class="ai-verdict-icon">${isPos?'📈':'📉'}</div>
        <div>
          <div class="ai-verdict-label">${isPos?'Positive expected value':'Thin / negative edge'}</div>
          <div style="font-size:11px;color:var(--text2);font-family:var(--font-mono)">EV: ${ev>=0?'+':''}${ev.toFixed(1)}% · Edge: ${edge>=0?'+':''}${edge.toFixed(1)}pp</div>
        </div>
      </div>
      <div class="ai-metrics">
        <div class="ai-metric">
          <div class="ai-metric-label">Implied %</div>
          <div class="ai-metric-val">${(imp*100).toFixed(1)}%</div>
        </div>
        <div class="ai-metric">
          <div class="ai-metric-label">Your %</div>
          <div class="ai-metric-val" style="color:var(--cyan)">${prob}%</div>
        </div>
        <div class="ai-metric">
          <div class="ai-metric-label">Kelly stake</div>
          <div class="ai-metric-val" style="color:var(--amber)">${kelly>0?kellySuggest+'%':'–'}</div>
        </div>
      </div>
      <div class="ai-text">${aiText}</div>
      <div style="margin-top:10px;display:flex;gap:8px">
        <button class="btn btn-primary btn-sm" id="send-to-log">Send to Home log</button>
        <button class="btn btn-ghost btn-sm" id="clear-analyzer">Clear</button>
      </div>
    `;

    document.getElementById('send-to-log').addEventListener('click',()=>{
      const t=betText;
      let league='Other';
      if(/nba/i.test(t)) league='NBA';
      else if(/nfl/i.test(t)) league='NFL';
      else if(/ucl/i.test(t)) league='UCL';
      else if(/nhl/i.test(t)) league='NHL';
      else if(/mlb/i.test(t)) league='MLB';
      S.bets.push({id:'b'+Date.now().toString(36),league,match:'',market:t.slice(0,60),odds,units,result:'pending',createdAt:Date.now()});
      saveState(); renderBetList();
      alert('Sent to Home log!');
    });

    document.getElementById('clear-analyzer').addEventListener('click',()=>{
      resultEl.className='ai-result';
      resultEl.innerHTML='';
    });

  }catch(err){
    resultEl.innerHTML=`<div class="ai-text" style="color:var(--red)">API error: ${err.message}. Check your network or API key.</div>`;
  }
}

