<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>BankrollBot Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg: #060a12;
  --bg2: #0c1220;
  --bg3: #111928;
  --surface: #141e2e;
  --surface2: #1a2640;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --green: #00e5a0;
  --green2: #00b87d;
  --cyan: #00c8f0;
  --amber: #f5a623;
  --red: #ff4d6a;
  --purple: #9b6dff;
  --text: #e8edf5;
  --text2: #8a96a8;
  --text3: #5a6478;
  --font-display: 'Syne', sans-serif;
  --font-mono: 'DM Mono', monospace;
  --font-body: 'DM Sans', sans-serif;
  --radius: 14px;
  --radius-sm: 8px;
  --glow-green: 0 0 30px rgba(0,229,160,0.15);
  --glow-cyan: 0 0 30px rgba(0,200,240,0.15);
}

*{box-sizing:border-box;margin:0;padding:0}

html,body{
min-height:100vh;
background:var(–bg);
color:var(–text);
font-family:var(–font-body);
font-size:14px;
line-height:1.5;
overflow-x:hidden;
}

/* Noise texture overlay */
body::before{
content:’’;
position:fixed;
inset:0;
background-image:url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘0.03’/%3E%3C/svg%3E”);
pointer-events:none;
z-index:0;
opacity:0.4;
}

.app{
position:relative;
z-index:1;
max-width:560px;
margin:0 auto;
min-height:100vh;
display:flex;
flex-direction:column;
padding-bottom:80px;
}

/* ─── HEADER ─── */
.header{
padding:20px 20px 0;
position:relative;
}

.header-glow{
position:absolute;
top:-40px;left:-60px;
width:300px;height:200px;
background:radial-gradient(ellipse,rgba(0,229,160,0.08) 0%,transparent 70%);
pointer-events:none;
}

.header-top{
display:flex;
align-items:center;
justify-content:space-between;
margin-bottom:16px;
}

.logo{
display:flex;
align-items:center;
gap:10px;
}

.logo-icon{
width:36px;height:36px;
border-radius:10px;
background:linear-gradient(135deg,var(–green),var(–cyan));
display:flex;align-items:center;justify-content:center;
font-size:16px;
box-shadow:0 4px 20px rgba(0,229,160,0.4);
flex-shrink:0;
}

.logo-name{
font-family:var(–font-display);
font-size:17px;
font-weight:800;
letter-spacing:0.02em;
color:var(–text);
}

.logo-sub{
font-family:var(–font-mono);
font-size:10px;
color:var(–text3);
letter-spacing:0.1em;
text-transform:uppercase;
margin-top:1px;
}

.sim-badge{
font-family:var(–font-mono);
font-size:10px;
padding:4px 10px;
border-radius:999px;
border:1px solid rgba(0,229,160,0.3);
color:var(–green);
background:rgba(0,229,160,0.06);
letter-spacing:0.08em;
text-transform:uppercase;
}

/* Stats strip */
.stats-strip{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:10px;
margin:0 20px 16px;
}

.stat-card{
background:var(–surface);
border:1px solid var(–border);
border-radius:var(–radius-sm);
padding:12px 14px;
position:relative;
overflow:hidden;
transition:border-color 0.2s;
}

.stat-card::before{
content:’’;
position:absolute;
top:0;left:0;right:0;
height:2px;
background:linear-gradient(to right,var(–green),var(–cyan));
opacity:0;
transition:opacity 0.2s;
}

.stat-card:hover::before{opacity:1}

.stat-label{
font-family:var(–font-mono);
font-size:9px;
color:var(–text3);
text-transform:uppercase;
letter-spacing:0.12em;
margin-bottom:4px;
}

.stat-val{
font-family:var(–font-display);
font-size:20px;
font-weight:700;
line-height:1;
color:var(–text);
}

.stat-val.up{color:var(–green)}
.stat-val.down{color:var(–red)}

.stat-sub{
font-size:10px;
color:var(–text3);
margin-top:3px;
font-family:var(–font-mono);
}

/* ─── NAV ─── */
.nav{
position:fixed;
bottom:0;left:50%;
transform:translateX(-50%);
width:100%;
max-width:560px;
background:rgba(6,10,18,0.92);
backdrop-filter:blur(20px);
border-top:1px solid var(–border);
display:grid;
grid-template-columns:repeat(5,1fr);
z-index:100;
padding:6px 0 8px;
}

.nav-btn{
background:none;border:none;
display:flex;flex-direction:column;
align-items:center;gap:3px;
padding:6px 4px;
cursor:pointer;
color:var(–text3);
font-family:var(–font-mono);
font-size:9px;
letter-spacing:0.08em;
text-transform:uppercase;
transition:color 0.15s;
position:relative;
}

.nav-btn .nav-icon{font-size:18px;line-height:1}

.nav-btn.active{color:var(–green)}

.nav-btn.active::after{
content:’’;
position:absolute;
bottom:-8px;
left:20%;right:20%;
height:2px;
background:linear-gradient(to right,var(–green),var(–cyan));
border-radius:999px;
}

/* ─── CONTENT ─── */
.content{padding:0 20px}

.screen{display:none}
.screen.active{display:block;animation:fadeUp 0.2s ease}

@keyframes fadeUp{
from{opacity:0;transform:translateY(6px)}
to{opacity:1;transform:translateY(0)}
}

/* ─── SECTION LABELS ─── */
.section-label{
font-family:var(–font-mono);
font-size:10px;
color:var(–text3);
text-transform:uppercase;
letter-spacing:0.14em;
margin:20px 0 8px;
}

/* ─── CARDS ─── */
.card{
background:var(–surface);
border:1px solid var(–border);
border-radius:var(–radius);
padding:16px;
margin-bottom:12px;
position:relative;
overflow:hidden;
}

.card-glow-green::after{
content:’’;
position:absolute;
top:-30px;right:-30px;
width:120px;height:120px;
background:radial-gradient(circle,rgba(0,229,160,0.07),transparent 70%);
pointer-events:none;
}

.card-title{
font-family:var(–font-display);
font-size:15px;
font-weight:700;
margin-bottom:4px;
}

.card-sub{
font-size:12px;
color:var(–text2);
margin-bottom:12px;
}

/* ─── FORMS ─── */
.form-group{margin-bottom:12px}

.form-label{
display:block;
font-family:var(–font-mono);
font-size:10px;
color:var(–text3);
text-transform:uppercase;
letter-spacing:0.1em;
margin-bottom:5px;
}

input,select,textarea{
width:100%;
background:var(–bg2);
border:1px solid var(–border2);
border-radius:var(–radius-sm);
padding:10px 12px;
color:var(–text);
font-family:var(–font-body);
font-size:13px;
outline:none;
transition:border-color 0.15s,box-shadow 0.15s;
}

input::placeholder,textarea::placeholder{color:var(–text3)}

input:focus,select:focus,textarea:focus{
border-color:var(–cyan);
box-shadow:0 0 0 2px rgba(0,200,240,0.1);
}

textarea{resize:vertical;min-height:80px}

select{background:var(–bg2);cursor:pointer}

.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}

/* ─── BUTTONS ─── */
.btn{
display:inline-flex;align-items:center;justify-content:center;
gap:7px;
padding:11px 20px;
border-radius:999px;
border:none;
font-family:var(–font-display);
font-size:13px;
font-weight:700;
cursor:pointer;
transition:all 0.15s;
letter-spacing:0.02em;
}

.btn-primary{
background:linear-gradient(135deg,var(–green),var(–cyan));
color:#060a12;
box-shadow:0 4px 20px rgba(0,229,160,0.25);
}

.btn-primary:hover{
box-shadow:0 6px 28px rgba(0,229,160,0.4);
transform:translateY(-1px);
}

.btn-primary:active{transform:translateY(0);box-shadow:none}

.btn-ghost{
background:var(–surface2);
border:1px solid var(–border2);
color:var(–text2);
}

.btn-ghost:hover{border-color:var(–green);color:var(–green)}

.btn-danger{
background:rgba(255,77,106,0.12);
border:1px solid rgba(255,77,106,0.3);
color:var(–red);
}

.btn-sm{padding:6px 14px;font-size:12px}

/* ─── BET LIST ─── */
.bet-item{
padding:12px 0;
border-bottom:1px solid var(–border);
display:flex;
gap:10px;
align-items:flex-start;
}

.bet-item:last-child{border-bottom:none}

.bet-league-dot{
width:6px;height:6px;
border-radius:50%;
background:var(–cyan);
margin-top:6px;
flex-shrink:0;
}

.bet-info{flex:1}

.bet-name{
font-weight:500;
font-size:13px;
margin-bottom:2px;
}

.bet-meta{
font-family:var(–font-mono);
font-size:10px;
color:var(–text3);
display:flex;gap:8px;flex-wrap:wrap;
}

.bet-actions{
display:flex;
gap:5px;
align-items:center;
flex-shrink:0;
}

.result-pill{
font-family:var(–font-mono);
font-size:10px;
padding:3px 8px;
border-radius:999px;
border:1px solid var(–border2);
color:var(–text3);
}

.result-pill.win{
border-color:rgba(0,229,160,0.5);
color:var(–green);
background:rgba(0,229,160,0.08);
}

.result-pill.loss{
border-color:rgba(255,77,106,0.5);
color:var(–red);
background:rgba(255,77,106,0.08);
}

.mark-btn{
padding:4px 9px;
border-radius:999px;
border:1px solid var(–border2);
background:var(–bg2);
font-family:var(–font-mono);
font-size:10px;
cursor:pointer;
color:var(–text3);
transition:all 0.12s;
}

.mark-btn.w:hover{border-color:var(–green);color:var(–green)}
.mark-btn.l:hover{border-color:var(–red);color:var(–red)}

/* ─── CHIPS / TAGS ─── */
.chip{
display:inline-flex;align-items:center;
font-family:var(–font-mono);
font-size:10px;
padding:3px 8px;
border-radius:999px;
border:1px solid var(–border2);
color:var(–text2);
background:var(–bg2);
}

.chip.green{
border-color:rgba(0,229,160,0.4);
color:var(–green);
background:rgba(0,229,160,0.06);
}

.chip.red{
border-color:rgba(255,77,106,0.4);
color:var(–red);
background:rgba(255,77,106,0.06);
}

.chip.amber{
border-color:rgba(245,166,35,0.4);
color:var(–amber);
background:rgba(245,166,35,0.06);
}

/* ─── AI RESULT ─── */
.ai-result{
margin-top:14px;
display:none;
}

.ai-result.visible{display:block;animation:fadeUp 0.3s ease}

.ai-verdict{
display:flex;align-items:center;gap:10px;
padding:12px 14px;
border-radius:var(–radius-sm);
margin-bottom:12px;
}

.ai-verdict.pos{
background:rgba(0,229,160,0.06);
border:1px solid rgba(0,229,160,0.2);
}

.ai-verdict.neg{
background:rgba(255,77,106,0.06);
border:1px solid rgba(255,77,106,0.2);
}

.ai-verdict-icon{font-size:22px}

.ai-verdict-label{
font-family:var(–font-display);
font-size:14px;
font-weight:700;
}

.ai-verdict.pos .ai-verdict-label{color:var(–green)}
.ai-verdict.neg .ai-verdict-label{color:var(–red)}

.ai-metrics{
display:grid;grid-template-columns:repeat(3,1fr);gap:8px;
margin-bottom:12px;
}

.ai-metric{
background:var(–bg2);
border:1px solid var(–border);
border-radius:var(–radius-sm);
padding:10px 12px;
text-align:center;
}

.ai-metric-label{
font-family:var(–font-mono);
font-size:9px;
color:var(–text3);
text-transform:uppercase;
letter-spacing:0.1em;
margin-bottom:4px;
}

.ai-metric-val{
font-family:var(–font-display);
font-size:16px;
font-weight:700;
}

.ai-text{
font-size:12px;
color:var(–text2);
line-height:1.65;
background:var(–bg2);
border-radius:var(–radius-sm);
padding:12px;
border:1px solid var(–border);
white-space:pre-wrap;
min-height:60px;
}

.ai-thinking{
display:flex;align-items:center;gap:8px;
font-family:var(–font-mono);
font-size:11px;
color:var(–cyan);
padding:12px;
}

.dots span{
display:inline-block;
animation:blink 1.2s infinite;
font-size:16px;
}
.dots span:nth-child(2){animation-delay:0.2s}
.dots span:nth-child(3){animation-delay:0.4s}

@keyframes blink{0%,80%,100%{opacity:0}40%{opacity:1}}

/* ─── CHART ─── */
.chart-wrap{
position:relative;
height:180px;
margin-bottom:8px;
}

/* ─── TOGGLE ─── */
.toggle-row{
display:flex;align-items:center;justify-content:space-between;
padding:12px 0;
border-bottom:1px solid var(–border);
gap:12px;
}

.toggle-row:last-child{border-bottom:none}

.toggle-info{flex:1}

.toggle-name{
font-size:13px;
font-weight:500;
margin-bottom:2px;
}

.toggle-desc{
font-size:11px;
color:var(–text3);
}

.toggle-track{
width:40px;height:22px;
border-radius:999px;
background:var(–bg3);
border:1px solid var(–border2);
position:relative;
cursor:pointer;
transition:background 0.2s,border-color 0.2s;
flex-shrink:0;
}

.toggle-track.on{
background:rgba(0,229,160,0.2);
border-color:var(–green);
}

.toggle-track::after{
content:’’;
position:absolute;
top:3px;left:3px;
width:14px;height:14px;
border-radius:50%;
background:var(–text3);
transition:transform 0.2s,background 0.2s;
}

.toggle-track.on::after{
transform:translateX(18px);
background:var(–green);
}

/* ─── COMMUNITY ─── */
.pick-item{
padding:14px 0;
border-bottom:1px solid var(–border);
}

.pick-item:last-child{border-bottom:none}

.pick-top{
display:flex;align-items:flex-start;
justify-content:space-between;gap:8px;
margin-bottom:6px;
}

.pick-title{
font-weight:500;
font-size:13px;
}

.pick-user{
font-family:var(–font-mono);
font-size:10px;
color:var(–text3);
margin-top:2px;
}

.pick-note{
font-size:12px;
color:var(–text2);
margin-bottom:8px;
}

.pick-bottom{
display:flex;align-items:center;gap:8px;
}

.vote-btn{
display:inline-flex;align-items:center;gap:4px;
padding:4px 10px;
border-radius:999px;
border:1px solid var(–border2);
background:var(–bg2);
font-family:var(–font-mono);
font-size:11px;
cursor:pointer;
color:var(–text3);
transition:all 0.12s;
}

.vote-btn:hover{border-color:var(–green);color:var(–green)}
.vote-btn.voted{border-color:var(–green);color:var(–green);background:rgba(0,229,160,0.08)}

/* ─── PROFILE ─── */
.avatar{
width:52px;height:52px;
border-radius:16px;
background:linear-gradient(135deg,var(–cyan),var(–purple));
display:flex;align-items:center;justify-content:center;
font-family:var(–font-display);
font-size:20px;
font-weight:800;
color:white;
margin-bottom:12px;
}

.profile-name-display{
font-family:var(–font-display);
font-size:22px;
font-weight:800;
margin-bottom:4px;
}

.profile-tag{
font-family:var(–font-mono);
font-size:11px;
color:var(–text3);
margin-bottom:14px;
}

.bar-group{margin-bottom:10px}

.bar-header{
display:flex;justify-content:space-between;
font-family:var(–font-mono);
font-size:10px;
color:var(–text3);
margin-bottom:5px;
}

.bar-track{
height:6px;
border-radius:999px;
background:var(–bg3);
overflow:hidden;
}

.bar-fill{
height:100%;
border-radius:999px;
background:linear-gradient(to right,var(–green),var(–cyan));
transition:width 0.5s ease;
}

/* ─── ALERTS (planner) ─── */
.alert-item{
padding:12px 0;
border-bottom:1px solid var(–border);
}

.alert-item:last-child{border-bottom:none}

.alert-top{
display:flex;align-items:flex-start;
justify-content:space-between;gap:8px;
margin-bottom:4px;
}

.alert-name{
font-weight:500;
font-size:13px;
}

.alert-time{
font-family:var(–font-mono);
font-size:10px;
color:var(–text3);
flex-shrink:0;
}

.alert-detail{
font-size:12px;
color:var(–text2);
margin-bottom:6px;
}

.alert-tags{display:flex;gap:5px;flex-wrap:wrap}

/* ─── SUPABASE NOTE ─── */
.setup-box{
background:linear-gradient(135deg,rgba(0,200,240,0.04),rgba(0,229,160,0.04));
border:1px solid rgba(0,200,240,0.15);
border-radius:var(–radius);
padding:16px;
margin-bottom:12px;
}

.setup-title{
font-family:var(–font-display);
font-size:14px;
font-weight:700;
margin-bottom:6px;
color:var(–cyan);
}

.setup-text{
font-size:12px;
color:var(–text2);
line-height:1.65;
margin-bottom:12px;
}

.setup-code{
background:var(–bg);
border:1px solid var(–border2);
border-radius:var(–radius-sm);
padding:10px 12px;
font-family:var(–font-mono);
font-size:11px;
color:var(–green);
line-height:1.7;
white-space:pre-wrap;
margin-bottom:10px;
overflow-x:auto;
}

/* ─── DIVIDER ─── */
.divider{
height:1px;
background:var(–border);
margin:16px 0;
}

/* ─── EMPTY STATE ─── */
.empty{
text-align:center;
padding:30px 20px;
color:var(–text3);
font-size:12px;
}

.empty-icon{font-size:32px;margin-bottom:8px}

/* ─── ODDS TICKER (planner) ─── */
.live-dot{
display:inline-block;
width:6px;height:6px;
border-radius:50%;
background:var(–red);
animation:pulse 1.5s infinite;
margin-right:5px;
}

@keyframes pulse{
0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(255,77,106,0.4)}
50%{opacity:0.7;box-shadow:0 0 0 4px rgba(255,77,106,0)}
}

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(–border2);border-radius:999px}

/* ─── RESPONSIVE ─── */
@media(max-width:480px){
.stats-strip{grid-template-columns:repeat(3,1fr);gap:6px}
.stat-val{font-size:17px}
.form-row{grid-template-columns:1fr}
}
</style>

</head>
