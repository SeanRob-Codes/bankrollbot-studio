let community=[
  {id:'c1',user:'SharpSprout',pick:'NBA · HOU +6.5 vs LAL',note:'Model has this closer to +3.9, tiny dog lean.',ev:'+2.1% EV (sim)',up:14,down:3,voted:false},
  {id:'c2',user:'UnitFarmer',pick:'NFL · Anytime TD: Kelce',note:'Price dipped; target share still elite.',ev:'+1.3% EV (high variance)',up:22,down:9,voted:false},
  {id:'c3',user:'ProbEdge',pick:'UCL · o2.5 goals BVB vs PSG',note:'Both top 10 in xG; tempo-friendly styles.',ev:'+3.4% EV (sim)',up:31,down:5,voted:false},
];

function renderCommunity(){
  const el=document.getElementById('community-list');
  el.innerHTML=community.map(item=>`
    <div class="pick-item" id="pick-${item.id}">
      <div class="pick-top">
        <div>
          <div class="pick-title">${item.pick}</div>
          <div class="pick-user">by ${item.user} · <span class="chip amber" style="font-size:9px">${item.ev}</span></div>
        </div>
      </div>
      <div class="pick-note">${item.note}</div>
      <div class="pick-bottom">
        <button class="vote-btn${item.voted?' voted':''}" data-id="${item.id}" data-dir="up">👍 ${item.up}</button>
        <button class="vote-btn" data-id="${item.id}" data-dir="down">👎 ${item.down}</button>
      </div>
    </div>
  `).join('');

  el.querySelectorAll('.vote-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const item=community.find(c=>c.id===btn.dataset.id);
      if(!item) return;
      if(btn.dataset.dir==='up'){ item.up++; item.voted=true; }
      else item.down++;
      renderCommunity();
    });
  });
}

document.getElementById('add-pick-btn').addEventListener('click',()=>{
  const pick=(document.getElementById('c-pick').value||'').trim();
  const note=(document.getElementById('c-note').value||'').trim();
  if(!pick){ alert('Add a pick description.'); return; }
  community.unshift({id:'c'+Date.now().toString(36),user:S.username||'You',pick,note:note||'No note.',ev:'EV not rated (local)',up:0,down:0,voted:false});
  document.getElementById('c-pick').value='';
  document.getElementById('c-note').value='';
  renderCommunity();
});

