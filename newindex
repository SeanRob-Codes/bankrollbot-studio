/* ──────────────────────────────────────────
   PROFILE
────────────────────────────────────────── */
function refreshProfileUI(){
  const st=calcStats();
  document.getElementById('prof-avatar').textContent=initials(S.username);
  document.getElementById('prof-name-display').textContent=S.username? S.username+"'s profile":'Your profile';
  document.getElementById('prof-tag').textContent=
    S.riskMode==='chill'?'Chill · 0.25–0.5u stakes':
    S.riskMode==='aggressive'?'Aggressive · 1–2u stakes':'Standard · 0.5–1u stakes';
  document.getElementById('p-name').value=S.username||'';
  document.getElementById('p-bankroll').value=S.bankroll;
  document.getElementById('p-unit').value=S.unitSize;
  document.getElementById('p-risk').value=S.riskMode;

  const drift=st.net*S.unitSize;
  let hp=50,hlabel='Neutral';
  if(drift>0){ hp=Math.min(100,50+drift/(S.bankroll*0.05)*50); hlabel='Up ↑'; }
  else if(drift<0){ hp=Math.max(0,50+drift/(S.bankroll*0.05)*50); hlabel='Down ↓'; }
  document.getElementById('health-label').textContent=hlabel;
  document.getElementById('health-bar').style.width=hp+'%';

  const wr=st.hitRate||0;
  document.getElementById('wr-label').textContent=st.hitRate!==null?wr.toFixed(1)+'%':'–';
  document.getElementById('wr-bar').style.width=(st.hitRate!==null?wr:0)+'%';

  const badges=document.getElementById('profile-badges');
  badges.innerHTML=`
    <div class="chip green">Sim player</div>
    <div class="chip">${S.riskMode==='chill'?'🧊 Chill':S.riskMode==='aggressive'?'🔥 Aggressive':'⚖️ Standard'}</div>
    ${st.hitRate!==null&&st.hitRate>=55?'<div class="chip green">🎯 Sharp hit rate</div>':''}
    ${st.net>5?'<div class="chip green">📈 +5u milestone</div>':''}
  `;
}

document.getElementById('save-profile-btn').addEventListener('click',()=>{
  S.username=(document.getElementById('p-name').value||'').trim();
  S.bankroll=parseFloat(document.getElementById('p-bankroll').value)||2500;
  S.unitSize=parseFloat(document.getElementById('p-unit').value)||25;
  S.riskMode=document.getElementById('p-risk').value;
  saveState();
  alert('Profile saved!');
});

document.getElementById('reset-btn').addEventListener('click',()=>{
  if(!confirm('Reset all demo data and profile?')) return;
  localStorage.removeItem(STORAGE_KEY);
  S=deepClone(DEFAULT);
  saveState();
  renderBetList();
  renderCommunity();
  renderAlerts();
  initGuardrailsUI();
  alert('Fresh slate!');
});

