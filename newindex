function initGuardrailsUI(){
  const g=S.guardrails;
  setToggle('t-stoploss',g.stopLossOn);
  setToggle('t-maxbets',g.maxBetsOn);
  setToggle('t-tilt',g.tiltOn);
  setToggle('t-kelly',g.kellyOn);
  document.getElementById('stoploss-val').value=g.stopLoss;
  document.getElementById('maxbets-val').value=g.maxBets;

  ['t-stoploss','t-maxbets','t-tilt','t-kelly'].forEach(id=>{
    document.getElementById(id).addEventListener('click',()=>{
      const map={'t-stoploss':'stopLossOn','t-maxbets':'maxBetsOn','t-tilt':'tiltOn','t-kelly':'kellyOn'};
      S.guardrails[map[id]]=!S.guardrails[map[id]];
      setToggle(id,S.guardrails[map[id]]);
      saveState();
    });
  });

  document.getElementById('stoploss-val').addEventListener('change',e=>{
    S.guardrails.stopLoss=parseFloat(e.target.value)||(-5); saveState();
  });
  document.getElementById('maxbets-val').addEventListener('change',e=>{
    S.guardrails.maxBets=parseInt(e.target.value)||5; saveState();
  });
}

function setToggle(id,on){
  document.getElementById(id).classList.toggle('on',on);
}

